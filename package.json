{
  "name": "music-tag-native",
  "version": "0.2.5",
  "description": "Music tag reader / writter in Node.js / Browser, powered by napi-rs and lofty",
  "keywords": [
    "FLAC",
    "ID3",
    "M4A",
    "MP3",
    "N-API",
    "NAPI",
    "Rust",
    "Vorbis",
    "WAV",
    "music",
    "napi-rs",
    "node-addon",
    "node-addon-api",
    "tags"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/subframe7536/music-tag-native.git"
  },
  "files": [
    "index.d.ts",
    "index.js",
    "browser.js"
  ],
  "main": "index.js",
  "browser": "browser.js",
  "types": "index.d.ts",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "dev": "napi build --watch --platform --target wasm32-wasip1-threads",
    "build": "napi build --platform --release --strip",
    "build:wasm": "napi build --platform --release --target wasm32-wasip1-threads",
    "build:debug": "napi build --platform",
    "typecheck": "tsc --noEmit",
    "oxc": "oxlint --fix && oxfmt",
    "qa": "pnpm run oxc && pnpm run typecheck",
    "test": "vitest run",
    "test:rebuild": "pnpm run build:debug && vitest run",
    "play": "vite serve playground",
    "test:watch": "vitest",
    "prepublishOnly": "napi prepublish -t npm",
    "release": "pnpm run qa && bumpp -x \"pnpm run test:rebuild\" --all"
  },
  "devDependencies": {
    "@emnapi/core": "^1.7.1",
    "@emnapi/runtime": "^1.7.1",
    "@napi-rs/cli": "^3.5.0",
    "@napi-rs/wasm-runtime": "^1.1.0",
    "@subf/config": "^0.2.1",
    "@tybys/wasm-util": "^0.10.1",
    "@types/node": "^24.10.1",
    "bumpp": "^10.3.2",
    "emnapi": "^1.7.1",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "napi": {
    "binaryName": "music-tag-native",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "x86_64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "i686-pc-windows-msvc",
      "aarch64-unknown-linux-gnu",
      "aarch64-linux-android",
      "aarch64-unknown-linux-musl",
      "aarch64-apple-darwin",
      "aarch64-pc-windows-msvc",
      "armv7-unknown-linux-gnueabihf",
      "armv7-unknown-linux-musleabihf",
      "wasm32-wasi-preview1-threads"
    ]
  },
  "engines": {
    "node": ">= 10"
  },
  "packageManager": "pnpm@10.33.4"
}
